{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "bobrapet Helm values",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "controllerManager",
    "kubernetesClusterDomain",
    "metricsService",
    "operatorConfig",
    "serviceAccount",
    "webhookService"
  ],
  "properties": {
    "controllerManager": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "manager",
        "nodeSelector",
        "podSecurityContext",
        "replicas",
        "tolerations",
        "topologySpreadConstraints"
      ],
      "properties": {
        "manager": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "args",
            "containerSecurityContext",
            "image",
            "imagePullPolicy",
            "resources"
          ],
          "properties": {
            "args": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "containerSecurityContext": {
              "type": "object"
            },
            "image": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "repository",
                "tag"
              ],
              "properties": {
                "repository": {
                  "type": "string",
                  "minLength": 1
                },
                "tag": {
                  "type": "string",
                  "minLength": 1
                }
              }
            },
            "imagePullPolicy": {
              "type": "string",
              "enum": [
                "Always",
                "IfNotPresent",
                "Never"
              ]
            },
            "resources": {
              "type": "object"
            }
          }
        },
        "nodeSelector": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "podSecurityContext": {
          "type": "object"
        },
        "replicas": {
          "type": "integer",
          "minimum": 1
        },
        "tolerations": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "topologySpreadConstraints": {
          "type": "array",
          "items": {
            "type": "object"
          }
        }
      }
    },
    "kubernetesClusterDomain": {
      "type": "string",
      "minLength": 1
    },
    "metricsService": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ports",
        "type"
      ],
      "properties": {
        "ports": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "port",
              "protocol",
              "targetPort"
            ],
            "properties": {
              "name": {
                "type": "string"
              },
              "port": {
                "type": "integer",
                "minimum": 1
              },
              "protocol": {
                "type": "string"
              },
              "targetPort": {
                "oneOf": [
                  {
                    "type": "integer",
                    "minimum": 1
                  },
                  {
                    "type": "string",
                    "minLength": 1
                  }
                ]
              }
            }
          }
        },
        "type": {
          "type": "string"
        }
      }
    },
    "operatorConfig": {
      "type": "object",
      "minProperties": 1
    },
    "serviceAccount": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "annotations",
        "automount",
        "create",
        "name"
      ],
      "properties": {
        "annotations": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "automount": {
          "type": "boolean"
        },
        "create": {
          "type": "boolean"
        },
        "name": {
          "type": "string"
        }
      }
    },
    "webhookService": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ports",
        "type"
      ],
      "properties": {
        "ports": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "port",
              "protocol",
              "targetPort"
            ],
            "properties": {
              "port": {
                "type": "integer",
                "minimum": 1
              },
              "protocol": {
                "type": "string"
              },
              "targetPort": {
                "oneOf": [
                  {
                    "type": "integer",
                    "minimum": 1
                  },
                  {
                    "type": "string",
                    "minLength": 1
                  }
                ]
              }
            }
          }
        },
        "type": {
          "type": "string"
        }
      }
    }
  }
}
